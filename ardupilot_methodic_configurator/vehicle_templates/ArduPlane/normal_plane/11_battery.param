BATT_ARM_VOLT,23.2998  # Only arm above this voltage, to avoid taking off with insufficient battery capacity
BATT_CAPACITY,3300  # Total battery capacity specified in the component editor
BATT_CRT_MAH,0
BATT_CRT_VOLT,21  # Critical failsafe voltage x nr. of cells
BATT_FS_CRT_ACT,1  # Land ASAP
BATT_FS_LOW_ACT,2  # Return and land at home or rally point
BATT_FS_VOLTSRC,0
BATT_LOW_MAH,0
BATT_LOW_VOLT,22.8  # Low failsafe voltage x nr. of cells
