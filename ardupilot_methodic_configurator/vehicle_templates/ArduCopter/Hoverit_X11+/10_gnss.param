BRD_BOOT_DELAY,7000  # Make sure the Here4 GNSS receivers fully boot before the Autopilot boots
BRD_SAFETY_DEFLT,1  # Use a safety switch
CAN_D2_PROTOCOL,1
CAN_P2_DRIVER,1
GPS1_GNSS_MODE,69
GPS1_POS_X,0
GPS1_POS_Y,0
GPS1_POS_Z,0
GPS1_TYPE,9
GPS2_GNSS_MODE,69
GPS2_POS_X,0
GPS2_POS_Y,0
GPS2_POS_Z,0
GPS2_TYPE,9
NTF_LED_TYPES,32  # DRONECAN LED
SERIAL3_PROTOCOL,-1  # NO SERIAL 3
SERIAL4_PROTOCOL,-1  # NO SERIAL 4
WPNAV_RADIUS,500  # 5 METER RADIUS TO WAYPOINT IS GOOD KEEPING INERTIA IN MIND
