INS_GYRO_FILTER,20  # as per initial parameter config
INS_HNTCH_ATT,20  # just enough to filter the noise created by the motors/propellers
INS_HNTCH_BW,9  # just enough to filter the noise created by the motors/propellers
INS_HNTCH_FM_RAT,0.62  # ratio between the noise start frequency and the noise peak frequency
INS_HNTCH_FREQ,20  # central hover frequency noise peak
INS_HNTCH_HMNCS,3  # only the first two peaks are above -50dB after filtering
INS_HNTCH_OPTS,2  # ESC telemetry delivers per motor RPM so use it to improve filter tracking
INS_HNTCH_REF,1  # Using ESC RPM data from ESC telemetry to track noise
LOG_BITMASK,145118  # Log all but fast att, Nav, Mission, OF, camera, fast IMU, raw, IMU, video stabilization. These are not needed now
