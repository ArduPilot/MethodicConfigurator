INS_HNTCH_ATT,30  # just enough to filter the noise created by the motors/propellers
INS_HNTCH_BW,6  # just enough to filter the noise created by the motors/propellers
INS_HNTCH_FM_RAT,0.5  # Allowed undercutting of the base frequency of the first notch filter
INS_HNTCH_FREQ,27  # the minimum frequency that the motors are expected to operate at
INS_HNTCH_HMNCS,3  # the motors produce secondary harmonics on this vehicle
INS_HNTCH_OPTS,2  # Use hobbywing datalink ESC RPM telemetry and one notch per motor
INS_HNTCH_REF,1  # Required by the ESC RPM telemetry
