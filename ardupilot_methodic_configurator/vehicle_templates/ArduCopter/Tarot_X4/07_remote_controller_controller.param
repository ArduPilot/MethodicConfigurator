ARMING_RUDDER,2  # Vehicle uses arm/disarm via sticks as well as emergency motor stop switch (shoulder switch of Radiomaster Boxer assigned to channel 5)
RC5_OPTION,31  # To stop all motors immediately if the vehicle starts moving dangerously - mapped to channel 5 / left shoulder toggle button (inverted on RC sender) because ELRS can transmit only 2 positions on channel 5
RC6_OPTION,0  # Used for flight mode selection
RC7_OPTION,0
RC8_OPTION,4  # force RTL
RC9_OPTION,0
